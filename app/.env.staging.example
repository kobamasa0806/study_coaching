# staging 環境の環境変数テンプレート
# 1. このファイルを .env.staging にコピー
#    cp .env.staging.example .env.staging
# 2. 値を実際のものに書き換える
# 3. .env.staging は絶対にコミットしない（.gitignore に追加済み）

# --- Django ---
# SECRET_KEY: ランダムな 50 文字以上の文字列を生成すること
#   生成例: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS
JWT_SIGNING_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHARS
# 管理画面パスは推測困難な文字列にする（末尾スラッシュ必須）
DJANGO_ADMIN_URL=staging-mgmt-9f3b/

# --- 公開ホスト ---
# ローカル検証時: localhost,127.0.0.1
# EC2 デプロイ後: staging-api.example.com を追加
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# HTTPS リダイレクト: ローカル検証時は 0、EC2 で TLS 設定後は 1
ENABLE_HTTPS=0

# --- PostgreSQL ---
DB_NAME=study_coaching
DB_USER=postgres
# ローカル検証用パスワード。EC2 デプロイ時は強固なものに変更
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- AWS Cognito (staging 用 User Pool) ---
# 開発用と staging 用は分離すること
AWS_COGNITO_REGION=ap-northeast-1
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_APP_CLIENT_ID=

# --- AWS IAM 認証（任意・AdminCreateUser 等を使う場合のみ）---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- nginx 公開ポート（ローカル検証時のみ）---
NGINX_HTTP_PORT=8080
